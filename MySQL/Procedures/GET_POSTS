DELIMITER //

CREATE PROCEDURE GET_POSTS ()
BEGIN
  SELECT 
    P.POST_ID,
    P.AUTHOR_ID,
    U.USERNAME,
    P.CONTENT,
    P.CREATED_AT,
    COUNT(L.POST_ID) AS LIKE_COUNT
  FROM POSTS P
  JOIN USERS U ON P.AUTHOR_ID = U.USER_ID
  LEFT JOIN LIKES L ON P.POST_ID = L.POST_ID
  GROUP BY P.POST_ID, P.AUTHOR_ID, U.USERNAME, P.CONTENT, P.CREATED_AT
  ORDER BY P.CREATED_AT DESC;
END //

DELIMITER ;